{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "glean-search",
  "title": "Glean Search",
  "description": "Search your company's knowledge base via Glean",
  "icon": "icon.png",
  "author": "faizhasim",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-glean",
      "title": "Search Glean",
      "description": "Search company docs via Glean CLI",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "react": "^18.2.0",
    "typescript": "^5.2.2",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "platforms": [
    "macOS"
  ]
}
