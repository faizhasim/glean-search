{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "glean-search",
  "title": "Glean Search",
  "description": "Search your company's knowledge base via Glean",
  "icon": "icon.png",
  "author": "faizhasim",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-glean",
      "title": "Search Glean",
      "description": "Search company docs via Glean CLI",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "type": "textfield",
      "name": "gleanHost",
      "title": "Glean Host",
      "description": "Your Glean server URL (e.g. https://your-company-be.glean.com)",
      "required": true,
      "placeholder": "https://your-company-be.glean.com"
    },
    {
      "type": "textfield",
      "name": "gleanCliPath",
      "title": "Custom CLI Path (optional)",
      "description": "Override the glean binary path if not in PATH",
      "required": false,
      "placeholder": "/opt/homebrew/bin/glean"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "react": "^18.2.0",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  },
  "platforms": [
    "macOS"
  ]
}
