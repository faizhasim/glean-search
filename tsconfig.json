{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node 18",
  "include": ["src/**/*", "raycast-env.d.ts", "vitest.config.ts", "__mocks__/**/*"],
  "compilerOptions": {
    "lib": ["es2021", "esnext.promise"],
    "module": "commonjs",
    "target": "es2021",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true
  },
  "exclude": ["src/**/*.test.ts", "__mocks__/**/*"]
}
